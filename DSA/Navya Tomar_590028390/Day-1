Question-1_LeetCode
int missingNumber(int* nums, int numsSize) {
    int expected = numsSize * (numsSize + 1) / 2;
    int actual = 0;

    for (int i = 0; i < numsSize; i++) {
        actual += nums[i];
    }

    return expected - actual;
}
Question-2
#include <stdio.h>

int sum(int arr[], int n) {
    int total = 0;

    for (int i = 0; i < n; i++) {
        total += arr[i];
    }

    return total;
}

int main() {
    int arr[] = {3, 8, 2, 9, 1};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d\n", sum(arr, n));

    return 0;
}
